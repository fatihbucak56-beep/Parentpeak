# Example environment file for Parentpeak
# Copy to .env and fill with real values.

# Project contact
PROJECT_CONTACT_EMAIL=parentpeakapp@gmail.com

# Legacy/demo service key (only needed for older revocation flow)
ABACUS_API_KEY=REPLACE_ME

# Gemini AI
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY

# Backend base and auth
BACKEND_BASE_URL=https://api.example.com
BACKEND_API_TOKEN=REPLACE_WITH_BACKEND_TOKEN

# Family and schema context
BACKEND_FAMILY_ID=demo-family-001
BACKEND_API_VERSION=v1

# Optional endpoint overrides
BACKEND_TODOS_PATH=/todos
BACKEND_SHOPPING_PATH=/shopping
BACKEND_CALENDAR_EVENTS_PATH=/calendar/events
BACKEND_HEALTH_PATH=/health
