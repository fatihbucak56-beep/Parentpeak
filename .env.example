# Example environment file for Parentpeak
# Copy to .env and fill with real values.

# Firebase Admin (Backend only — niemals in Flutter .env!)
# Service Account JSON als Einzeiler (Zeilenumbrüche durch \n ersetzen)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Firebase Storage Bucket für Bild-Uploads (Format: <projectId>.firebasestorage.app)
# Wird automatisch aus FIREBASE_SERVICE_ACCOUNT_JSON abgeleitet wenn nicht gesetzt.
FIREBASE_STORAGE_BUCKET=parentpeak-prod-2026.firebasestorage.app

# Legacy/demo service key (only needed for older revocation flow)
ABACUS_API_KEY=REPLACE_ME

# Gemini AI
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY
GEMINI_MODEL_NAME=gemini-2.0-flash

# Backend base and auth
BACKEND_BASE_URL=https://api.example.com
BACKEND_API_TOKEN=REPLACE_WITH_BACKEND_TOKEN

# Backend security controls (Node backend)
# In production: set to 1 so POST/PUT/PATCH/DELETE require Authorization Bearer BACKEND_API_TOKEN
REQUIRE_AUTH_FOR_WRITES=1
# Comma-separated allowlist — PFLICHTFELD in Production!
# Beispiel: https://parentpeak.de,https://www.parentpeak.de
# Leer lassen blockiert in Production alle Cross-Origin-Anfragen.
CORS_ALLOWED_ORIGINS=https://parentpeak.de,https://www.parentpeak.de
# Simple write-rate limiter tuning
WRITE_RATE_LIMIT_WINDOW_MS=900000
WRITE_RATE_LIMIT_MAX=120
# Internal moderation and expert-verification reviewers are configured on the backend only:
# INTERNAL_MODERATOR_EMAILS=lead@parentpeak.de,ops@parentpeak.de
# INTERNAL_MODERATOR_DOMAINS=parentpeak.de,parentpeak.com

# Family and schema context
BACKEND_FAMILY_ID=demo-family-001
BACKEND_API_VERSION=v1

# Optional endpoint overrides
BACKEND_TODOS_PATH=/todos
BACKEND_SHOPPING_PATH=/shopping
BACKEND_CALENDAR_EVENTS_PATH=/calendar/events
BACKEND_HEALTH_PATH=/health
BACKEND_PHOTOS_PATH=/photos
BACKEND_PARENT_MATCHING_PROFILES_PATH=/parent-matching/profiles
BACKEND_PARENT_MATCHING_ACTIONS_PATH=/parent-matching/actions
BACKEND_FAMILY_CONTACTS_PATH=/family/contacts
BACKEND_FAMILY_REQUESTS_PATH=/family/requests
BACKEND_WEEKLY_IMPULSE_PATH=/api/weekly-impulse
BACKEND_EVENTS_PATH=/events
BACKEND_EVENT_INVITATIONS_PATH=/events/invitations
BACKEND_EVENT_INVITATIONS_JOIN_PATH=/events/invitations/join
BACKEND_HOSTED_INVITE_ONLY_EVENTS_PATH=/events/hosted-invite-only
BACKEND_PAYMENTS_STRIPE_INIT_PATH=/payments/stripe/initiate
BACKEND_PAYMENTS_PAYPAL_INIT_PATH=/payments/paypal/initiate
BACKEND_PAYMENTS_CONFIRM_PATH=/payments/confirm
BACKEND_PAYMENTS_PROVIDER_EVENTS_PATH=/payments/provider-events
BACKEND_PAYMENTS_TRANSACTIONS_PATH=/payments/transactions
BACKEND_PAYMENTS_HOST_PATH=/payments/host
BACKEND_PAYMENTS_PATH=/payments
BACKEND_PAYMENT_TRANSACTIONS_PATH=/payments/transactions
BACKEND_ACCOUNT_DELETE_DATA_PATH=/account/delete-data
BACKEND_ENTITLEMENTS_PATH=/entitlements
BACKEND_ENTITLEMENTS_ACTIVATE_PREMIUM_SUFFIX=/activate-premium
BACKEND_PROVIDERS_PATH=/api/providers
BACKEND_PROVIDER_CATEGORIES_PATH=/api/categories
BACKEND_PROVIDER_SEARCH_PATH=/api/search
BACKEND_PROVIDER_FILTER_PATH=/api/providers/filter

# Stripe Publishable Key (safe to commit — not a secret)
# Get from: Stripe Dashboard -> Developers -> API keys
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# IMPORTANT: Never place Stripe server secrets in Flutter .env
# Server-only vars live in backend/.env or Render dashboard:
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_WEBHOOK_TOLERANCE_SEC

# Client-side provider-event ingestion switch
# Production default is 0 (recommended), dev default is 1 if unset.
ALLOW_CLIENT_PROVIDER_EVENTS=0
