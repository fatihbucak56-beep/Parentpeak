# ============================================================================
# DATABASE CONFIGURATION (Required for Production)
# ============================================================================

# Get this URL from Render PostgreSQL database
# Format: postgresql://user:password@internal-host:5432/dbname
# See docs/POSTGRES_PRISMA_IMPLEMENTATION.md for setup instructions
DATABASE_URL="postgresql://user:password@host:5432/parentpeak_db"

# ============================================================================
# STRIPE CONFIGURATION
# ============================================================================

# STRIPE_SECRET_KEY (Required for Production Payments)
# 🔐 NEVER commit this to Git or share publicly!
# Get from Stripe Dashboard: https://dashboard.stripe.com/apikeys
# Test Mode: starts with "sk_test_"
# Live Mode: starts with "sk_live_"
# Add to Render Dashboard ENVIRONMENT VARIABLES (not in Git)
STRIPE_SECRET_KEY="sk_test_YOUR_SECRET_KEY_HERE"

# Webhook Secret for payment event verification
# Get from Stripe Dashboard: Settings > Webhooks > Endpoint Details
# Used to verify that webhook events actually come from Stripe
STRIPE_WEBHOOK_SECRET="whsec_3Lp3U0gA2dseCCtKuSArnMqow75b9rqP"

# Time tolerance for Stripe webhook timestamp validation (in seconds)
STRIPE_WEBHOOK_TOLERANCE_SEC="300"

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

PORT=3000
NODE_ENV="production"

# ============================================================================
# CORS & SECURITY
# ============================================================================

# Allowed origins for CORS (comma-separated)
CORS_ALLOWED_ORIGINS="https://parentpeak.onrender.com,https://parentpeak.de,http://localhost:3000"

# ============================================================================
# RATE LIMITING
# ============================================================================

# Write request rate limit window in milliseconds (default: 15 minutes)
WRITE_RATE_LIMIT_WINDOW_MS="900000"

# Maximum write requests per window per IP
WRITE_RATE_LIMIT_MAX_REQUESTS="100"

# ============================================================================
# BACKEND AUTH
# ============================================================================

# Bearer token for write operations (set in Render for production)
BACKEND_API_TOKEN="your-secure-token-here"

# Whether to allow client-side provider event creation (disable in production)
ALLOW_CLIENT_PROVIDER_EVENTS="0"
