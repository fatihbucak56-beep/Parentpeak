// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AUTHENTICATION & USERS
// ============================================================================

model User {
  id                    String   @id @default(cuid())
  email                 String   @unique
  passwordHash          String
  passwordSalt          String
  firstName             String?
  lastName              String?
  avatar                String?
  bio                   String?
  
  // Trial/Premium Entitlements
  createdAt             DateTime @default(now())
  trialExpiresAt        DateTime?
  isPremium             Boolean  @default(false)
  premiumExpiresAt      DateTime?
  
  // Relations - unique names for each relation
  createdFamilies       Family[]        @relation("FamilyCreator")
  familyMemberships     Family[]        @relation("FamilyMembers")
  hostedEvents          Event[]         @relation("EventHost")
  eventParticipations   EventParticipation[]
  paymentTransactions   PaymentTransaction[]
  messages              Message[]
  chatReports           ChatReport[]
  
  @@index([email])
  @@index([createdAt])
}

// ============================================================================
// FAMILY & SOCIAL
// ============================================================================

model Family {
  id                    String   @id @default(cuid())
  name                  String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Creator of family
  createdById           String
  createdByUser         User     @relation("FamilyCreator", fields: [createdById], references: [id], onDelete: Cascade)
  
  // Members of family
  memberUsers           User[]   @relation("FamilyMembers")
  
  // Child relations
  events                Event[]
  todos                 Todo[]
  shoppingItems         ShoppingItem[]
  
  @@index([createdById])
}

model FamilyRequest {
  id                    String   @id @default(cuid())
  fromUserId            String
  toUserId              String
  status                String   @default("pending") // pending, accepted, declined
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([fromUserId])
  @@index([toUserId])
}

// ============================================================================
// EVENTS
// ============================================================================

model Event {
  id                    String   @id @default(cuid())
  title                 String
  description           String?
  
  // Host/Creator
  hosterId              String
  hoster                User     @relation("EventHost", fields: [hosterId], references: [id], onDelete: Cascade)
  
  // Family context (optional)
  familyId              String?
  family                Family?  @relation(fields: [familyId], references: [id], onDelete: SetNull)
  
  // Timing & Location
  startDate             DateTime
  endDate               DateTime?
  location              String?
  latitude              Float?
  longitude             Float?
  
  // Event Status & Type
  status                String   @default("upcoming") // upcoming, ongoing, completed, cancelled
  eventType             String   @default("generic") // generic, birthday, meeting, outing, etc.
  visibility            String   @default("publicNearby") // publicNearby, familyCircle, privateOnly, inviteOnly
  shareRadiusKm         Float    @default(25)
  inviteCode            String?  @unique
  inviteCodeExpiresAt   DateTime?
  
  // Pricing (optional)
  costPerPerson         Decimal? @db.Decimal(10, 2)
  currency              String   @default("EUR")
  maxParticipants       Int?
  
  // Metadata
  imageUrl              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  participants          EventParticipation[]
  chat                  EventChat?
  paymentTransactions   PaymentTransaction[]
  
  @@index([hosterId])
  @@index([familyId])
  @@index([status])
  @@index([visibility])
  @@index([createdAt])
}

model EventParticipation {
  id                    String   @id @default(cuid())
  
  eventId               String
  event                 Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  status                String   @default("invited") // invited, accepted, declined, attended
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@unique([eventId, userId])
  @@index([userId])
  @@index([status])
}

// ============================================================================
// EVENT CHAT & MESSAGING
// ============================================================================

model EventChat {
  id                    String   @id @default(cuid())
  
  eventId               String   @unique
  event                 Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  messages              Message[]
  reports               ChatReport[]
  
  @@index([eventId])
}

model Message {
  id                    String   @id @default(cuid())
  
  chatId                String
  chat                  EventChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  
  authorId              String
  author                User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  content               String
  attachmentUrl         String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  reports               ChatReport[]
  
  @@index([chatId])
  @@index([authorId])
  @@index([createdAt])
}

model ChatReport {
  id                    String   @id @default(cuid())
  
  messageId             String
  message               Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  reportedById          String
  reportedBy            User     @relation(fields: [reportedById], references: [id], onDelete: Cascade)
  
  chatId                String
  chat                  EventChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  
  reason                String   // spam, offensive, inappropriate, etc.
  details               String?
  status                String   @default("pending") // pending, reviewed, resolved, dismissed
  
  createdAt             DateTime @default(now())
  resolvedAt            DateTime?
  
  @@index([messageId])
  @@index([reportedById])
  @@index([status])
}

// ============================================================================
// PAYMENTS & TRANSACTIONS
// ============================================================================

model PaymentTransaction {
  id                    String   @id @default(cuid())
  
  eventId               String
  event                 Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Payment Details
  amount                Decimal  @db.Decimal(10, 2)
  currency              String   @default("EUR")
  stripePaymentIntentId String   @unique
  stripeChargId         String?
  
  // Idempotency
  idempotencyKey        String   @unique
  
  // Status
  status                String   @default("pending") // pending, succeeded, failed, refunded
  
  // Refund tracking
  refundedAmount        Decimal? @db.Decimal(10, 2)
  refundedAt            DateTime?
  refundReason          String?
  
  // Audit trail
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  verifiedAt            DateTime?
  verifiedByType        String?  // "webhook", "manual", "api"
  auditDetails          Json?
  
  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([stripePaymentIntentId])
}

// ============================================================================
// MARKETPLACE & PROVIDERS
// ============================================================================

model Provider {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  contactEmail          String
  contactPhone          String?
  website               String?
  imageUrl              String?
  
  // Provider categorization
  category              String   // catering, decoration, entertainment, venue, etc.
  
  // Location
  city                  String?
  country               String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([category])
  @@index([city])
}

// ============================================================================
// FAMILY UTILITIES
// ============================================================================

model Todo {
  id                    String   @id @default(cuid())
  title                 String
  description           String?
  done                  Boolean  @default(false)
  
  familyId              String
  family                Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime @default(now())
  dueDate               DateTime?
  completedAt           DateTime?
  
  @@index([familyId])
  @@index([done])
}

model ShoppingItem {
  id                    String   @id @default(cuid())
  name                  String
  quantity              Int      @default(1)
  bought                Boolean  @default(false)
  
  familyId              String
  family                Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime @default(now())
  boughtAt              DateTime?
  
  @@index([familyId])
  @@index([bought])
}

// ============================================================================
// PARENT MATCHING
// ============================================================================

model ParentMatchingProfile {
  id                    String   @id @default(cuid())
  externalId            String?  @unique
  name                  String
  age                   Int
  city                  String
  bio                   String?
  interests             String[]
  languages             String[]
  valuesFocus           String[]
  childAges             String[]
  familyForm            String
  verificationLevel     String   @default("basic")
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  actions               ParentMatchingAction[]

  @@index([city])
  @@index([isActive])
  @@index([createdAt])
}

model ParentMatchingAction {
  id                    String   @id @default(cuid())
  familyId              String
  profileId             String
  action                String
  createdAt             DateTime @default(now())
  actorUserId           String?

  profile               ParentMatchingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([profileId])
  @@index([action])
  @@index([createdAt])
  @@index([actorUserId])
}
